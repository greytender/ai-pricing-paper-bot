# ── Semantic Scholar API ────────────────────────────────────────
# 申请地址: https://www.semanticscholar.org/product/api#api-key-form
# 非必须，但有 Key 可提高速率限制
SEMANTIC_SCHOLAR_KEY=

# ── Zotero API ───────────────────────────────────────────────────
# 申请地址: https://www.zotero.org/settings/keys/new
ZOTERO_API_KEY=
ZOTERO_USER_ID=

# 方式一：直接指定 Collection Key（优先使用）
ZOTERO_COLLECTION_KEY=

# 方式二：通过名称查找/创建（当方式一未配置时生效）
ZOTERO_COLLECTION_NAME=AI Pricing - Game Theory
